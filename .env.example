# Base URL of the Acro Hub backend API (no trailing slash).
# Copy this file to .env.local and update as needed.
#
# In production the CloudFront distribution proxies /api/* to api.acrohub.org,
# so all API calls are same-origin and CORS is avoided entirely.
# The Vite dev-server proxy mirrors this behavior locally (see vite.config.js).
VITE_API_BASE_URL=/api

# Vite dev-server proxy target (server-side only – not exposed to the browser).
# Set this to the actual backend URL when developing locally.
API_PROXY_TARGET=https://api.acrohub.org
